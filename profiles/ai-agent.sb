(version 1)
(deny default)
(import "dyld-support.sb")

(allow process-exec)
(allow process-fork)
(allow signal (target same-sandbox))
(allow user-preference-read)
(allow process-info* (target same-sandbox))

(allow file-read* file-write-data
  (require-all
    (path "/dev/null")
    (vnode-type CHARACTER-DEVICE)))

(allow file-read* file-test-existence
  (literal "/")
  (literal "/dev/autofs_nowait")
  (literal "/dev/random")
  (literal "/dev/urandom")
  (literal "/private/etc/master.passwd")
  (literal "/private/etc/passwd")
  (literal "/private/etc/protocols")
  (literal "/private/etc/services")
  (literal "/private/var/db/DarwinDirectory/local/recordStore.data")
  (subpath "/private/var/db/timezone"))

(allow file-read* file-test-existence file-write-data
  (literal "/dev/zero"))

(allow file-read* file-test-existence
  (subpath "/dev/fd"))

(allow sysctl-read
  (sysctl-name "hw.activecpu")
  (sysctl-name "hw.busfrequency")
  (sysctl-name "hw.busfrequency_compat")
  (sysctl-name "hw.byteorder")
  (sysctl-name "hw.cacheconfig")
  (sysctl-name "hw.cachelinesize")
  (sysctl-name "hw.cachelinesize_compat")
  (sysctl-name "hw.cachesize")
  (sysctl-name "hw.cpu64bit_capable")
  (sysctl-name "hw.cpufamily")
  (sysctl-name "hw.cpufrequency")
  (sysctl-name "hw.cpufrequency_compat")
  (sysctl-name "hw.cpufrequency_max")
  (sysctl-name "hw.cpusubfamily")
  (sysctl-name "hw.cpusubtype")
  (sysctl-name "hw.cputype")
  (sysctl-name "hw.l1dcachesize")
  (sysctl-name "hw.l1dcachesize_compat")
  (sysctl-name "hw.l1icachesize")
  (sysctl-name "hw.l1icachesize_compat")
  (sysctl-name "hw.l2cachesize")
  (sysctl-name "hw.l2cachesize_compat")
  (sysctl-name "hw.l2settings")
  (sysctl-name "hw.l3cachesize")
  (sysctl-name "hw.l3cachesize_compat")
  (sysctl-name "hw.l3settings")
  (sysctl-name "hw.logicalcpu")
  (sysctl-name "hw.logicalcpu_max")
  (sysctl-name "hw.machine")
  (sysctl-name "hw.memsize")
  (sysctl-name "hw.model")
  (sysctl-name "hw.ncpu")
  (sysctl-name "hw.nperflevels")
  (sysctl-name-prefix "hw.optional.")
  (sysctl-name "hw.packages")
  (sysctl-name "hw.pagesize_compat")
  (sysctl-name "hw.pagesize")
  (sysctl-name "hw.physicalcpu")
  (sysctl-name "hw.physicalcpu_max")
  (sysctl-name "hw.physmem")
  (sysctl-name "hw.product")
  (sysctl-name "hw.target")
  (sysctl-name "hw.tbfrequency")
  (sysctl-name "hw.tbfrequency_compat")
  (sysctl-name "hw.usermem")
  (sysctl-name "hw.vectorunit")
  (sysctl-name "kern.hostname")
  (sysctl-name "kern.maxfilesperproc")
  (sysctl-name "kern.maxproc")
  (sysctl-name "kern.osproductversion")
  (sysctl-name "kern.osrelease")
  (sysctl-name "kern.ostype")
  (sysctl-name "kern.osvariant_status")
  (sysctl-name "kern.osversion")
  (sysctl-name "kern.secure_kernel")
  (sysctl-name "kern.usrstack64")
  (sysctl-name "kern.version")
  (sysctl-name "sysctl.proc_cputype")
  (sysctl-name "vm.loadavg")
  ;; Needed by /usr/sbin/sysctl to resolve names and display formats.
  (sysctl-name-prefix "sysctl.name")
  (sysctl-name "sysctl.name2oid")
  (sysctl-name-prefix "sysctl.oidfmt.")
  (sysctl-name "sysctl.proc_native")
  (sysctl-name-prefix "hw.perflevel")
  (sysctl-name-prefix "kern.proc.pgrp.")
  (sysctl-name-prefix "kern.proc.pid.")
  (sysctl-name-prefix "net.routetable."))

(allow iokit-open
  (iokit-registry-entry-class "RootDomainUserClient"))

(allow iokit-open-user-client
  (require-all
    (iokit-connection "AppleHDAEngineOutput")
    (iokit-user-client-class
      "IOAudioControlUserClient"
      "IOAudioEngineUserClient"))
  (iokit-user-client-class "AppleUpstreamUserClient")
  (iokit-user-client-class "AudioAUUC"))

(allow mach-lookup
  (xpc-service-name "com.apple.audio.AudioConverterService")
  (global-name "com.apple.FSEvents")
  (global-name "com.apple.system.opendirectoryd.libinfo")
  (global-name "com.apple.PowerManagement.control")
  (global-name "com.apple.SecurityServer")
  (global-name "com.apple.audio.AudioComponentPrefs")
  (global-name "com.apple.audio.AudioComponentRegistrar")
  (global-name "com.apple.audio.AudioConverterService")
  (global-name "com.apple.audio.AudioQueueServer")
  (global-name "com.apple.audio.AudioSession")
  (global-name "com.apple.audio.audiohald")
  (global-name "com.apple.audio.coreaudiod")
  (global-name "com.apple.audioanalyticsd")
  (global-name "com.apple.ocspd")
  (global-name "com.apple.relatived.public")
  (global-name "com.apple.relatived.status")
  (global-name "com.apple.relatived.tempest")
  (global-name "com.apple.trustd.agent")
  (global-name "com.apple.bsd.dirhelper")
  (global-name "com.apple.system.opendirectoryd.membership")
  (global-name "com.apple.system.notification_center"))

(allow ipc-posix-sem)

(allow network-outbound
  (remote tcp)
  (literal "/private/var/run/mDNSResponder"))
(allow network-inbound)
(allow system-socket)

(allow file-read-metadata file-test-existence
  (subpath "/"))

(allow file*
  (literal "/dev/tty")
  (literal (param "TTY_DEVICE")))

(allow file-read* file-map-executable file-test-existence process-exec*
  (subpath "/bin")
  (subpath "/sbin")
  (subpath "/usr/bin")
  (subpath "/usr/lib")
  (subpath "/usr/libexec")
  (subpath "/usr/sbin")
  (subpath "/usr/share")
  (subpath "/Library/Apple")
  (subpath "/Library/Developer")
  (subpath "/Library/Filesystems/NetFSPlugins")
  (subpath "/Library/Preferences/Logging")
  (subpath "/Applications/Xcode.app/Contents/Developer")
  (subpath "/System")
  (subpath "/usr/local/Cellar")
  (subpath "/usr/local/bin")
  (subpath "/usr/local/opt")
  (subpath "/opt/homebrew/Cellar")
  (subpath "/opt/homebrew/bin")
  (subpath "/opt/homebrew/opt")
  (subpath "/nix/store"))

(allow file-read* file-map-executable file-test-existence
  (subpath "/Library/Audio")
  (subpath "/System/Volumes/macOS/Library/Audio"))

(allow file-read* file-test-existence
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/etc")
  (subpath "/private/etc")
  (subpath "/usr/local/etc")
  (subpath "/usr/local/share")
  (subpath "/opt/homebrew/etc")
  (subpath "/opt/homebrew/share")
  (subpath (param "GIT_XDG_CONFIG"))
  (literal (param "HOME_PROFILE"))
  (literal (param "HOME_BASH_PROFILE"))
  (literal (param "HOME_BASHRC"))
  (literal (param "HOME_ZPROFILE"))
  (literal (param "HOME_ZSHENV"))
  (literal (param "HOME_ZSHRC")))

(allow file-read* file-write* file-map-executable file-test-existence process-exec*
  (subpath (param "WORKSPACE")))

(allow file-read* file-write* file-test-existence
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath (param "CLAUDE_HOME"))
  (literal (param "CLAUDE_JSON"))
  (subpath (param "CLAUDE_XDG_CONFIG"))
  (subpath (param "CLAUDE_XDG_CACHE"))
  (subpath (param "CLAUDE_XDG_DATA"))
  (subpath (param "CLAUDE_XDG_STATE"))
  (subpath (param "CLAUDE_DARWIN_APP_SUPPORT"))
  (subpath (param "CLAUDE_DARWIN_CACHE"))
  (subpath (param "CLAUDE_DARWIN_LOGS"))
  (subpath (param "OPENCODE_XDG_CONFIG"))
  (subpath (param "OPENCODE_XDG_CACHE"))
  (subpath (param "OPENCODE_XDG_DATA"))
  (subpath (param "OPENCODE_XDG_STATE"))
  (subpath (param "OPENCODE_DARWIN_APP_SUPPORT"))
  (subpath (param "OPENCODE_DARWIN_CACHE"))
  (subpath (param "OPENCODE_DARWIN_LOGS")))

(allow file-read* file-map-executable file-test-existence process-exec*
  (subpath (param "RUSTUP_HOME"))
  (subpath (param "CARGO_HOME"))
  (subpath (param "PNPM_HOME"))
  (subpath (param "YARN_HOME")))

(allow file-read* file-write* file-map-executable file-test-existence process-exec*
  (subpath (param "NPM_CACHE"))
  (subpath (param "PNPM_STORE"))
  (subpath (param "PNPM_CACHE"))
  (subpath (param "PNPM_STATE"))
  (subpath (param "YARN_BERRY"))
  (subpath (param "YARN_CACHE"))
  (subpath (param "YARN_CACHE_XDG"))
  (subpath (param "COREPACK_CACHE"))
  (subpath (param "COREPACK_CACHE_DARWIN")))

(allow file-read* file-write* file-test-existence
  (subpath (param "CARGO_REGISTRY"))
  (subpath (param "CARGO_GIT"))
  (literal (param "CARGO_PACKAGE_CACHE"))
  (literal (param "CARGO_HOME"))
  (literal (param "YARN_HOME")))

(allow file-read* file-test-existence
  (subpath (param "PNPM_CONFIG"))
  (subpath (param "YARN_CONFIG"))
  (literal (param "NPM_RC"))
  (literal (param "YARN_RC"))
  (literal (param "YARN_RC_YML")))

(allow file-read* file-write* file-test-existence
  (subpath (param "HOME_KEYCHAINS")))
(allow file-read* file-test-existence
  (literal "/Library/Keychains/System.keychain")
  (subpath "/System/Library/Keychains"))

(allow file-read* file-write* file-test-existence
  (subpath "/private/var/db/mds"))
(allow ipc-posix-shm*)

(allow file-read* file-write* file-test-existence
  (subpath (param "DARWIN_USER_CACHE"))
  (subpath (param "DARWIN_USER_TEMP")))
